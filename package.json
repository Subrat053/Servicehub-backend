{
  "name": "servicehub-backend",
  "version": "1.0.0",
  "description": "ServiceHub Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "port:check": "node utils/port-tools.js check 5000",
    "port:kill": "node utils/port-tools.js kill 5000",
    "dev:clean": "npm run port:kill && npm run dev",
    "seed": "node utils/seed.js",
    "seed:fresh": "node utils/seedFreshState.js",
    "migrate:reviews": "node utils/migrateReviews.js --write",
    "migrate:reviews:dry": "node utils/migrateReviews.js",
    "migrate:plans": "node utils/migratePlansAndSubscriptions.js --write",
    "migrate:plans:dry": "node utils/migratePlansAndSubscriptions.js"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.2",
    "socket.io": "^4.8.3",
    "stripe": "^20.4.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
