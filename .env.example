# Copy this file to .env and fill in your values.

PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=servicehub
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of your deployed frontend (Vercel / Netlify / custom domain)
# Examples:
#   Local dev  → http://localhost:5173
#   Vercel     → https://servicehub.vercel.app
#   Netlify    → https://servicehub.netlify.app
#   Custom     → https://yourdomain.com
FRONTEND_URL=https://your-frontend-url.com

# ─── Business Logic ───────────────────────────────────────────────────────────
FREE_SKILLS_LIMIT=4
FREE_PROFILE_VIEW_LIMIT=10
ROTATION_POOL_SIZE=5
ROTATION_INTERVAL_SEC=60
FEATURED_LIMIT=5
SEARCH_RADIUS_KM=50
PROFILE_VALIDITY_DAYS=365

# ─── Exchange Rates ──────────────────────────────────────────────────────────
# Currency conversion uses exchangerate-api USD base and derives INR pairs.
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD

# Number of trusted proxy hops for Express (0 for local/no proxy)
TRUST_PROXY_HOPS=0

# Geoapify (Location autocomplete + nearby places)
GEOAPIFY_API_KEY=your_geoapify_api_key
# Cache duration in milliseconds (default: 1 hour)
EXCHANGE_RATE_CACHE_TTL_MS=3600000

# ─── Geo / Locale Detection (optional) ───────────────────────────────────────
# If you are behind Cloudflare/Vercel, country headers are auto-used.
# Otherwise backend falls back to ipapi.co for country/currency/language hints.

# ─── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
# Add your backend domain to Authorized JavaScript origins and redirect URIs.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ─── Email (SMTP / Transactional Provider) ───────────────────────────────────
# Works with Gmail SMTP, SendGrid SMTP relay, Mailgun SMTP, Brevo SMTP, etc.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=ServiceHub
EMAIL_OTP_VALIDITY_MINUTES=10

# ─── WhatsApp Business API (Meta Cloud API) ───────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_OTP_TEMPLATE_NAME=your_otp_template_name
WHATSAPP_OTP_TEMPLATE_LANG=en
WHATSAPP_WELCOME_TEMPLATE_NAME=your_welcome_template_name

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
